# ============================================
# Configuración del proyecto RAG
# Renombra este archivo a .env
# ============================================

# OpenAI API Key (para el LLM de generación)
OPENAI_API_KEY=sk-tu-api-key-aqui

# Modelo de OpenAI a usar
OPENAI_MODEL=gpt-4o

# ============================================
# Embeddings
# ============================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# Vector Store
# ============================================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_documentos

# ============================================
# Chunking Estructural Inteligente
# ============================================
MAX_CHUNK_SIZE=4000
MIN_CHUNK_SIZE=100

# ============================================
# OCR (Tesseract)
# ============================================
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_LANG=spa+eng

# ============================================
# Pinecone (para migración futura)
# ============================================
# PINECONE_API_KEY=tu-pinecone-api-key
# PINECONE_INDEX_NAME=rag-documentos
# PINECONE_ENVIRONMENT=us-east-1

# ============================================
# Telegram MVP (Taxpy)
# ============================================
# Token del bot creado en @BotFather
TELEGRAM_BOT_TOKEN=

# Si true, solo entra quien use /start CODIGO
TELEGRAM_REQUIRE_INVITE=false

# Lista de codigos permitidos separada por coma (ej: beta2026,taxpy)
TELEGRAM_INVITE_CODES=

# Freemium MVP
TELEGRAM_FREE_QUERIES_PER_MONTH=10
TELEGRAM_PRO_PLAN_PRICE_USD=27

# DB sqlite local para usuarios/uso telegram
TELEGRAM_DB_PATH=./taxpy_telegram.sqlite3

# ============================================
# API MVP (web -> backend Python)
# ============================================
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000

# Token opcional para proteger endpoints (/ask, /usage).
# Si lo dejas vacio, no exige auth.
API_ACCESS_TOKEN=

# DB sqlite local para uso y cuota de la API
API_DB_PATH=./taxpy_api.sqlite3
